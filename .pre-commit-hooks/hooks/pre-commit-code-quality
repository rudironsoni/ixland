#!/bin/bash
# Pre-commit hook for code quality checks
# This hook runs on staged files before commit
#
# To install: ./scripts/install-hooks.sh
# Or manually: ln -s ../../.pre-commit-hooks/hooks/pre-commit-code-quality .git/hooks/pre-commit-code-quality

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

echo "=========================================="
echo "Pre-commit Code Quality Checks"
echo "=========================================="

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

EXIT_CODE=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# =============================================================================
# C/C++ Code Formatting Check
# =============================================================================
check_c_formatting() {
    local files="$1"
    local c_files=""
    
    # Filter for C/C++ files
    for file in $files; do
        if [[ "$file" =~ \.(c|h|cpp|hpp)$ ]]; then
            # Skip certain directories
            if [[ ! "$file" =~ /(wamr|node_modules|Resources|.build)/ ]]; then
                c_files="$c_files $file"
            fi
        fi
    done
    
    if [ -z "$c_files" ]; then
        return 0
    fi
    
    if ! command -v clang-format &> /dev/null; then
        echo -e "${YELLOW}WARNING: clang-format not found, skipping C formatting check${NC}"
        return 0
    fi
    
    echo "Checking C/C++ code formatting..."
    local unformatted=0
    
    for file in $c_files; do
        if [ -f "$file" ]; then
            if ! clang-format --dry-run --Werror "$file" > /dev/null 2>&1; then
                echo -e "  ${RED}❌ $file${NC}"
                unformatted=$((unformatted + 1))
                EXIT_CODE=1
            fi
        fi
    done
    
    if [ $unformatted -eq 0 ]; then
        echo -e "  ${GREEN}✓ All C/C++ files formatted correctly${NC}"
    else
        echo ""
        echo -e "${RED}C/C++ formatting issues found in $unformatted file(s)${NC}"
        echo "Run './scripts/format.sh --fix' to auto-fix formatting"
    fi
}

# =============================================================================
# Swift Code Formatting Check
# =============================================================================
check_swift_formatting() {
    local files="$1"
    local swift_files=""
    
    # Filter for Swift files in ixland-app
    for file in $files; do
        if [[ "$file" =~ \.swift$ ]] && [[ "$file" =~ ^ixland-app/ ]]; then
            swift_files="$swift_files $file"
        fi
    done
    
    if [ -z "$swift_files" ]; then
        return 0
    fi
    
    if ! command -v swiftlint &> /dev/null; then
        echo -e "${YELLOW}WARNING: SwiftLint not found, skipping Swift formatting check${NC}"
        return 0
    fi
    
    echo "Checking Swift code formatting..."
    
    cd "$PROJECT_ROOT/ixland-app"
    local has_issues=0
    
    for file in $swift_files; do
        # Get relative path from ixland-app
        local rel_file="${file#ixland-app/}"
        if [ -f "$rel_file" ]; then
            if ! swiftlint lint --path "$rel_file" --quiet 2>/dev/null; then
                echo -e "  ${RED}❌ $file${NC}"
                has_issues=1
                EXIT_CODE=1
            fi
        fi
    done
    
    cd "$PROJECT_ROOT"
    
    if [ $has_issues -eq 0 ]; then
        echo -e "  ${GREEN}✓ All Swift files pass linting${NC}"
    else
        echo ""
        echo -e "${RED}Swift linting issues found${NC}"
        echo "Run 'cd ixland-app && swiftlint --fix' to auto-fix issues"
    fi
}

# =============================================================================
# Shell Script Check
# =============================================================================
check_shell_scripts() {
    local files="$1"
    local shell_files=""
    
    # Filter for shell scripts
    for file in $files; do
        if [[ "$file" =~ \.sh$ ]] || [[ "$file" =~ /scripts/[^/]+$ ]]; then
            # Skip certain directories
            if [[ ! "$file" =~ /(Resources|node_modules|.dolt)/ ]]; then
                # Check if it's a shell script
                if [ -f "$file" ] && head -1 "$file" | grep -q "#!/.*sh"; then
                    shell_files="$shell_files $file"
                fi
            fi
        fi
    done
    
    if [ -z "$shell_files" ]; then
        return 0
    fi
    
    if ! command -v shellcheck &> /dev/null; then
        echo -e "${YELLOW}WARNING: ShellCheck not found, skipping shell script check${NC}"
        return 0
    fi
    
    echo "Checking shell scripts..."
    local issues=0
    
    for file in $shell_files; do
        if [ -f "$file" ]; then
            if ! shellcheck -S warning "$file" > /dev/null 2>&1; then
                echo -e "  ${RED}❌ $file${NC}"
                issues=$((issues + 1))
                EXIT_CODE=1
            fi
        fi
    done
    
    if [ $issues -eq 0 ]; then
        echo -e "  ${GREEN}✓ All shell scripts pass checks${NC}"
    else
        echo ""
        echo -e "${RED}ShellCheck issues found in $issues file(s)${NC}"
        echo "Run 'shellcheck <file>' to see details"
    fi
}

# =============================================================================
# Trailing Whitespace Check
# =============================================================================
check_trailing_whitespace() {
    local files="$1"
    local text_files=""
    
    # Filter for text files
    for file in $files; do
        if [[ "$file" =~ \.(c|h|cpp|hpp|swift|sh|yml|yaml|json|md|txt)$ ]]; then
            text_files="$text_files $file"
        fi
    done
    
    if [ -z "$text_files" ]; then
        return 0
    fi
    
    echo "Checking for trailing whitespace..."
    local issues=0
    
    for file in $text_files; do
        if [ -f "$file" ]; then
            # Skip binary files and generated files
            if [[ "$file" =~ \.(plist|xcscheme|pbxproj)$ ]]; then
                continue
            fi
            
            if grep -n '[[:space:]]$' "$file" > /dev/null 2>&1; then
                echo -e "  ${RED}❌ $file${NC}"
                issues=$((issues + 1))
                EXIT_CODE=1
            fi
        fi
    done
    
    if [ $issues -eq 0 ]; then
        echo -e "  ${GREEN}✓ No trailing whitespace found${NC}"
    else
        echo ""
        echo -e "${RED}Trailing whitespace found in $issues file(s)${NC}"
        echo "Run 'sed -i "" "s/[[:space:]]*$//" <file>' to fix"
    fi
}

# =============================================================================
# Large File Check
# =============================================================================
check_large_files() {
    local files="$1"
    local max_size=1048576  # 1MB in bytes
    
    echo "Checking for large files..."
    local large_files=0
    
    for file in $files; do
        if [ -f "$file" ]; then
            local size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
            if [ "$size" -gt "$max_size" ]; then
                local size_mb=$(echo "scale=2; $size / 1048576" | bc 2>/dev/null || echo "$((size / 1048576))")
                echo -e "  ${YELLOW}⚠ $file (${size_mb}MB)${NC}"
                large_files=$((large_files + 1))
            fi
        fi
    done
    
    if [ $large_files -eq 0 ]; then
        echo -e "  ${GREEN}✓ No large files found${NC}"
    else
        echo ""
        echo -e "${YELLOW}Warning: $large_files large file(s) detected${NC}"
        echo "Consider using Git LFS for files > 1MB"
    fi
}

# =============================================================================
# Main
# =============================================================================

# Skip checks if --no-verify is used
if [ "$SKIP_CODE_QUALITY_CHECKS" = "1" ]; then
    echo "Skipping code quality checks (SKIP_CODE_QUALITY_CHECKS=1)"
    exit 0
fi

# Run checks
check_c_formatting "$STAGED_FILES"
echo ""

check_swift_formatting "$STAGED_FILES"
echo ""

check_shell_scripts "$STAGED_FILES"
echo ""

check_trailing_whitespace "$STAGED_FILES"
echo ""

check_large_files "$STAGED_FILES"
echo ""

# =============================================================================
# Summary
# =============================================================================
echo "=========================================="
echo "Pre-commit Checks Complete"
echo "=========================================="

if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✓ All checks passed!${NC}"
else
    echo ""
    echo -e "${RED}Some checks failed. Please fix the issues before committing.${NC}"
    echo ""
    echo "To bypass these checks (not recommended):"
    echo "  git commit --no-verify"
    echo "  # or"
    echo "  SKIP_CODE_QUALITY_CHECKS=1 git commit"
fi

exit $EXIT_CODE

# iXland EditorConfig
# Helps maintain consistent coding styles across editors
# https://editorconfig.org

root = true

# Global settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ files
[*.{c,h,cpp,hpp}]
indent_style = space
indent_size = 4
max_line_length = 100

# Swift files
[*.swift]
indent_style = space
indent_size = 4
max_line_length = 120

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 4
max_line_length = 100

# CMake files
[CMakeLists.txt]
indent_style = space
indent_size = 2

[*.cmake]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# JSON files
[*.json]
indent_style = space
indent_size = 2

# XML files
[*.xml]
indent_style = space
indent_size = 2

# Property list files
[*.plist]
indent_style = space
indent_size = 4

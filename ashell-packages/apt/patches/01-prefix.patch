     // Check for root (not applicable on iOS, but keep logic)
     if (geteuid() != 0) {
         // On iOS, we don't need root for local PREFIX
-        // _error->Warning("Not running as root - may not be able to install packages");
+        // iOS: Running as mobile user in sandbox, package installation works
     }

     // Process packages to install

--- a/methods/CMakeLists.txt
+++ b/methods/CMakeLists.txt
@@ -10,7 +10,7 @@ set(METHODS
     rred
 )

-set(METHODS_DIR "${CMAKE_INSTALL_PREFIX}/lib/apt/methods")
+set(METHODS_DIR "@ASHELL_PREFIX@/lib/apt/methods")

 foreach(method ${METHODS})
     add_executable(${method} ${method}.cc)

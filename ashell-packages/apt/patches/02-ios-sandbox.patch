From: a-Shell Team <team@ashell.dev>
Date: Tue, 18 Mar 2026 00:00:00 +0000
Subject: [PATCH 02/03] iOS sandbox compatibility fixes

This patch removes or modifies features that don't work within
iOS sandbox constraints:
- Remove CD-ROM support (no optical drive access)
- Remove chroot functionality (sandbox violation)
- Disable privilege dropping (not needed in sandbox)
- Replace fork/exec with posix_spawn or simulation

--- a/apt-pkg/contrib/cdromutl.cc
+++ b/apt-pkg/contrib/cdromutl.cc
@@ -30,6 +30,12 @@
 #include <apti18n.h>

 using namespace std;

+// iOS: CD-ROM support disabled (no optical drive access in sandbox)
+#ifdef __APPLE__
+#include <TargetConditionals.h>
+#if TARGET_OS_IOS
+#define APT_DISABLE_CDROM 1
+#endif
+#endif
+
 // IsMounted - Check if the mount point is mounted
 bool IsMounted(string &Mount)
 {
@@ -50,6 +56,13 @@ bool MountCdrom(string &Path, string &MountPoint, bool ReadOnly)
     if (MountPoint.empty() == false && IsMounted(MountPoint) == true)
         return true;

+    // iOS: CD-ROM mounting not supported
+    #ifdef APT_DISABLE_CDROM
+    _error->Error("CD-ROM support is not available on iOS");
+    return false;
+    #endif
+
     // Try to mount the CD-ROM
     // ... rest of function
 }

--- a/apt-pkg/deb/dpkgpm.cc
+++ b/apt-pkg/deb/dpkgpm.cc
@@ -40,6 +40,15 @@
 #include <apti18n.h>
 #include <macro.h>

+// iOS: Replace fork/exec with posix_spawn
+#ifdef __APPLE__
+#include <TargetConditionals.h>
+#if TARGET_OS_IOS
+#include <spawn.h>
+#define USE_POSIX_SPAWN 1
+#endif
+#endif
+
 using namespace std;

 // DpkgPM::DpkgPM - Constructor
@@ -100,6 +109,25 @@ bool DpkgPM::RunScriptsWithPkgs(const char *Cnf)
     if (List.empty() == true)
         return true;

+    // iOS: Use posix_spawn instead of fork/exec
+    #ifdef USE_POSIX_SPAWN
+    for (const auto &script : List) {
+        pid_t pid;
+        const char *args[] = {script.c_str(), nullptr};
+        int status = posix_spawn(&pid, script.c_str(), nullptr, nullptr,
+                                 const_cast<char* const*>(args), environ);
+        if (status != 0) {
+            _error->Error("Failed to spawn %s: %s", script.c_str(), strerror(status));
+            return false;
+        }
+        int ret;
+        waitpid(pid, &ret, 0);
+        if (WIFEXITED(ret) == false || WEXITSTATUS(ret) != 0)
+            return false;
+    }
+    return true;
+    #endif
+
     // Standard fork/exec implementation
     for (const auto &script : List) {
         pid_t pid = fork();

--- a/apt-pkg/contrib/srvrec.cc
+++ b/apt-pkg/contrib/srvrec.cc
@@ -25,6 +25,14 @@
 #include <apti18n.h>
 #include <macro.h>

+// iOS: SRV record lookup may require special entitlements
+#ifdef __APPLE__
+#include <TargetConditionals.h>
+#if TARGET_OS_IOS
+// Use standard getaddrinfo instead of res_query
+#define APT_USE_GETADDRINFO_SRV 1
+#endif
+#endif
+
 using namespace std;

 // SRV record structure
@@ -50,6 +58,16 @@ bool GetSrvRecords(const string &Name, vector<SrvRec> &Result)
     Result.clear();

+    #ifdef APT_USE_GETADDRINFO_SRV
+    // iOS: Simplified SRV lookup using getaddrinfo
+    struct addrinfo hints = {}, *res;
+    hints.ai_family = AF_UNSPEC;
+    hints.ai_socktype = SOCK_STREAM;
+
+    if (getaddrinfo(Name.c_str(), "http", &hints, &res) != 0)
+        return false;
+    #endif
+
     // Standard SRV record lookup using res_query
     unsigned char response[2048];
     int len = res_query(Name.c_str(), C_IN, T_SRV, response, sizeof(response));


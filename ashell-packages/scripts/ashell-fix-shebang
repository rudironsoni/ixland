#!/bin/bash
# ashell-fix-shebang - Fix script shebang lines for a-Shell
# Usage: ashell-fix-shebang [options] <file|directory>
#
# Options:
#   --use-env    Use #!/usr/bin/env interpreter instead of direct path
#   --dry-run    Show changes without modifying files
#   --help       Show this help
#
# Examples:
#   ashell-fix-shebang script.sh              # Rewrite #!/bin/sh to #!$PREFIX/bin/sh
#   ashell-fix-shebang --use-env script.sh    # Rewrite to #!/usr/bin/env sh
#   ashell-fix-shebang /usr/local/bin/        # Fix all scripts in directory

set -e

# Default PREFIX (can be overridden)
ASHELL_PREFIX="${ASHELL_PREFIX:-\$HOME/Library/ashell}"
USE_ENV=false
DRY_RUN=false

# Common shebang replacements
# Format: "pattern:replacement"
SHEBANG_MAP=(
    "#!/bin/sh:#!$ASHELL_PREFIX/bin/sh"
    "#!/bin/bash:#!$ASHELL_PREFIX/bin/bash"
    "#!/bin/dash:#!$ASHELL_PREFIX/bin/dash"
    "#!/bin/awk:#!$ASHELL_PREFIX/bin/awk"
    "#!/bin/sed:#!$ASHELL_PREFIX/bin/sed"
    "#!/bin/grep:#!$ASHELL_PREFIX/bin/grep"
    "#!/usr/bin/perl:#!$ASHELL_PREFIX/bin/perl"
    "#!/usr/bin/python:#!$ASHELL_PREFIX/bin/python"
    "#!/usr/bin/python3:#!$ASHELL_PREFIX/bin/python3"
    "#!/usr/bin/lua:#!$ASHELL_PREFIX/bin/lua"
    "#!/usr/bin/env:#!/usr/bin/env"  # Keep env-based shebangs
)

# Show usage
usage() {
    sed -n '2,12p' "$0" | sed 's/^# //'
    exit 0
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --use-env)
            USE_ENV=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --help|-h)
            usage
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

if [[ -z "$TARGET" ]]; then
    echo "Error: No file or directory specified" >&2
    usage
fi

# Get interpreter name from path
get_interpreter_name() {
    local path="$1"
    basename "$path"
}

# Fix shebang in a single file
fix_shebang_file() {
    local file="$1"

    # Check if it's a text file
    if [[ ! -f "$file" ]] || file "$file" | grep -q "executable"; then
        # Skip binary files
        return 0
    fi

    # Read first line
    local first_line
    first_line=$(head -n 1 "$file" 2>/dev/null) || return 0

    # Check if it's a shebang
    if [[ ! "$first_line" =~ ^#! ]]; then
        return 0
    fi

    local new_shebang=""
    local interpreter=""

    if [[ "$USE_ENV" == true ]]; then
        # Convert to #!/usr/bin/env interpreter
        if [[ "$first_line" =~ ^#!/([^[:space:]]+)([[:space:]]+.*)?$ ]]; then
            local path="${BASH_REMATCH[1]}"
            local args="${BASH_REMATCH[2]}"
            interpreter=$(get_interpreter_name "$path")

            # Don't change if already using env
            if [[ "$path" != "usr/bin/env" ]]; then
                new_shebang="#!/usr/bin/env $interpreter$args"
            fi
        fi
    else
        # Convert hardcoded paths to PREFIX paths
        for mapping in "${SHEBANG_MAP[@]}"; do
            local pattern="${mapping%%:*}"
            local replacement="${mapping##*:}"

            if [[ "$first_line" == "$pattern"* ]]; then
                # Preserve any arguments after the interpreter
                local args="${first_line#$pattern}"
                new_shebang="$replacement$args"
                break
            fi
        done
    fi

    # Apply change if needed
    if [[ -n "$new_shebang" && "$new_shebang" != "$first_line" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "Would fix: $file"
            echo "  From: $first_line"
            echo "  To:   $new_shebang"
        else
            # Create temp file with new shebang
            local temp_file
            temp_file=$(mktemp)
            echo "$new_shebang" > "$temp_file"
            tail -n +2 "$file" >> "$temp_file"
            mv "$temp_file" "$file"
            chmod +x "$file"
            echo "Fixed: $file"
        fi
    fi
}

# Process target
if [[ -f "$TARGET" ]]; then
    fix_shebang_file "$TARGET"
elif [[ -d "$TARGET" ]]; then
    echo "Processing directory: $TARGET"
    find "$TARGET" -type f -print0 | while IFS= read -r -d '' file; do
        fix_shebang_file "$file"
    done
else
    echo "Error: $TARGET is not a file or directory" >&2
    exit 1
fi

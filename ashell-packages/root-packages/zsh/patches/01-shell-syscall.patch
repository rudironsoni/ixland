From: a-Shell Build System
Subject: Replace fork/exec with a_shell_* syscalls

Make zsh work with a-shell-kernel's process simulation instead
of native fork/exec which is unavailable on iOS.

--- a/Src/exec.c
+++ b/Src/exec.c
@@ -50,6 +50,16 @@
  #include "exec.pro"
  #include "math.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */
++#include "a_shell_system.h"
++#define fork a_shell_fork
++#define execve a_shell_execve
++#define execv a_shell_execv
++#define waitpid a_shell_waitpid
++#define exit a_shell_exit
++#define _exit a_shell_exit
++#endif
++
  /* These can be ints because they are not used as signal handlers. */
  int list_pipe_pid;
  int last_pid = -1;


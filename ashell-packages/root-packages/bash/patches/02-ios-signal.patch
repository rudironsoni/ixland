From: a-Shell Build System
Subject: Handle signals with a-shell-kernel

Replace signal handling with a-shell-kernel's signal implementation
which uses pthread-based signal emulation.

--- a/lib/sh/oslib.c
+++ b/lib/sh/oslib.c
@@ -50,6 +50,12 @@
  #include <unistd.h>
  #include <errno.h>

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel signal handling */
++#include "a_shell_system.h"
++#define signal a_shell_signal
++#endif
++
  /* Make sure the BSD setpgrp is used, not the SYSV one.  We need to be
     careful to include unistd.h before any file that may include
     sys/wait.h, POSIX.1 waitpid is declared there. */
@@ -200,8 +206,13 @@ set_signal_handler (int sig, SigHandler * handler)
  #if defined (HAVE_SIGACTION)
    struct sigaction act, oact;

+#ifdef __APPLE__
+  /* iOS: Use a-shell-kernel signal handling */
+  a_shell_signal(sig, handler);
+#else
    act.sa_handler = handler;
    sigemptyset (&act.sa_mask);
    act.sa_flags = 0;
    sigaction (sig, &act, &oact);
    return (oact.sa_handler);
+#endif
  }

--- a/shell.c
+++ b/shell.c
@@ -100,6 +100,13 @@
  #include "input.h"
  #include "trap.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel signal handling */
++#include "a_shell_system.h"
++#define signal a_shell_signal
++#endif
++
  /* Non-zero means this shell is running interactively. */
  int interactive = 0;
  int interactive_shell = 0;
@@ -500,8 +507,13 @@ initialize_shell (int argc, char **argv)
    /* Initialize signal handlers. */
    initialize_signals ();

+#ifdef __APPLE__
+  /* iOS: Use a-shell-kernel signal handling */
+  a_shell_signal(SIGINT, sigint_sighandler);
+#else
    /* Set up SIGINT handler. */
    set_signal_handler (SIGINT, sigint_sighandler);
+#endif

    /* Initialize the job control system. */
    initialize_job_control ();

--- a/jobs.c
+++ b/jobs.c
@@ -100,6 +100,13 @@
  #include "sig.h"
  #include "trap.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel signal handling */
++#include "a_shell_system.h"
++#define signal a_shell_signal
++#endif
++
  #if defined (HAVE_UNISTD_H)
  #include <unistd.h>
  #endif
@@ -1500,8 +1507,13 @@ initialize_job_control (void)
    /* Initialize job control. */
    job_control = 1;

+#ifdef __APPLE__
+  /* iOS: Use a-shell-kernel signal handling */
+  a_shell_signal(SIGTSTP, SIG_IGN);
+#else
    /* Ignore SIGTSTP. */
    set_signal_handler (SIGTSTP, SIG_IGN);
+#endif

    /* Initialize the terminal. */
    get_tty_state ();

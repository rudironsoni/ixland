--- a/execute_cmd.c
+++ b/execute_cmd.c
@@ -60,6 +60,17 @@
  #include "builtins/common.h"
  #include "builtins/builtext.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */

--- a/posixwait.h
+++ b/posixwait.h
@@ -25,6 +25,14 @@
  #ifndef _POSIXWAIT_H_
  #define _POSIXWAIT_H_

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */
++#include "a_shell_system.h"
++#define fork a_shell_fork
++#define waitpid a_shell_waitpid
++#define WIFEXITED(status) (a_shell_full_waitpid(-1, &(status), 0) > 0)
++#endif
++
  /* We must define WCOREDUMP if it is not defined, even if HAVE_SYS_WAIT_H
     is defined. */

--- a/shell.c
+++ b/shell.c
@@ -100,6 +100,16 @@

From: a-Shell Build System
Subject: Replace fork/exec with a_shell_* syscalls

Make bash work with a-shell-kernel's process simulation instead
of native fork/exec which is unavailable on iOS.

--- a/lib/sh/oslib.c
+++ b/lib/sh/oslib.c
@@ -50,6 +50,14 @@
  #include <unistd.h>
  #include <errno.h>

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */
++#include "a_shell_system.h"
++#define fork a_shell_fork
++#define execve a_shell_execve
++#define waitpid a_shell_waitpid
++#endif
++
  /* Make sure the BSD setpgrp is used, not the SYSV one.  We need to be
     careful to include unistd.h before any file that may include
     sys/wait.h, POSIX.1 waitpid is declared there. */

--- a/jobs.c
+++ b/jobs.c
@@ -100,6 +100,14 @@
  #include "sig.h"
  #include "trap.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */
++#include "a_shell_system.h"
++#define fork a_shell_fork
++#define execve a_shell_execve
++#define waitpid a_shell_waitpid
++#define kill a_shell_killpid
++#endif
++
  #if defined (HAVE_UNISTD_H)
  #include <unistd.h>
  #endif

--- a/builtins/common.c
+++ b/builtins/common.c
@@ -50,6 +50,14 @@
  #include "trap.h"
  #include "pathexp.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls */

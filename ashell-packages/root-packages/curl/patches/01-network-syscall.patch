From: a-Shell Build System
Subject: Replace fork/exec with a_shell_* syscalls for subprocess

Make curl's subprocess handling work with a-shell-kernel's process
simulation for features like --exec or subprocess spawning.

--- a/lib/asyn-thread.c
+++ b/lib/asyn-thread.c
@@ -50,6 +50,14 @@
  #include "curl_memory.h"
  #include "memdebug.h"

++#ifdef __APPLE__
++/* iOS: Use a-shell-kernel syscalls for threading */
++#include "a_shell_system.h"
++#define fork a_shell_fork
++#define waitpid a_shell_waitpid
++#define exit a_shell_exit
++#endif
++
  #if defined(USE_THREADS_POSIX)
  #  ifdef HAVE_PTHREAD_H
  #    include <pthread.h>


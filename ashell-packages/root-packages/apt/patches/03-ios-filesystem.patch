From: a-Shell Build System
Subject: iOS filesystem adaptations

Adapt apt for iOS filesystem model:
- Use NSFileManager for directory operations
- Handle app container paths
- Disable CD-ROM and other unavailable features
- Adapt cache/log directory locations

--- a/apt-pkg/aptconfiguration.cc
+++ b/apt-pkg/aptconfiguration.cc
@@ -45,8 +45,20 @@ string GetTempDir()
 // GetTempDir - Get system temporary directory
 string GetTempDir()
 {
+   #ifdef __APPLE__
+   // iOS: Use NSTemporaryDirectory via a-shell-kernel
+   extern "C" {
+      #include "a_shell_system.h"
+   }
+   const char* tmpdir = a_shell_getenv("TMPDIR");
+   if (tmpdir != nullptr && strlen(tmpdir) > 0)
+      return string(tmpdir);
+   // Fallback to app container
+   return "@ASHELL_PREFIX@/tmp";
+   #else
    const char* tmpdir = getenv("TMPDIR");
    if (tmpdir != nullptr && strlen(tmpdir) > 0)
       return string(tmpdir);
    return "/tmp";
+   #endif
 }

--- a/apt-pkg/acquire.cc
+++ b/apt-pkg/acquire.cc
@@ -89,6 +89,15 @@ bool pkgAcquire::Clean()
 // SetupDownloadDirectory - Setup download directory with iOS paths
 bool SetupDownloadDirectory()
 {
+   #ifdef __APPLE__
+   // iOS: Use app-specific directories
+   CacheDir = "@ASHELL_PREFIX@/var/cache/apt/archives";
+   LogDir = "@ASHELL_PREFIX@/var/log/apt";
+   StateDir = "@ASHELL_PREFIX@/var/lib/apt";
+   EtcDir = "@ASHELL_PREFIX@/etc/apt";
+   return true;
+   #endif
+
    CacheDir = _config->FindDir("Dir::Cache::Archives", "/var/cache/apt/archives");
    LogDir = _config->FindDir("Dir::Log", "/var/log/apt");
    return true;

--- a/apt-pkg/deb/debsystem.cc
+++ b/apt-pkg/deb/debsystem.cc
@@ -89,8 +89,15 @@ bool pkgDebianSystem::Initialize(Configuration &Cnf)
 {
    // Set up directories for iOS
-   Cnf.CndSet("Dir::Cache", "/var/cache/apt");
-   Cnf.CndSet("Dir::State", "/var/lib/apt");
-   Cnf.CndSet("Dir::Log", "/var/log/apt");
+   #ifdef __APPLE__
+   Cnf.CndSet("Dir::Cache", "@ASHELL_PREFIX@/var/cache/apt");
+   Cnf.CndSet("Dir::State", "@ASHELL_PREFIX@/var/lib/apt");
+   Cnf.CndSet("Dir::Log", "@ASHELL_PREFIX@/var/log/apt");
+   #else
+   Cnf.CndSet("Dir::Cache", "/var/cache/apt");
+   Cnf.CndSet("Dir::State", "/var/lib/apt");
+   Cnf.CndSet("Dir::Log", "/var/log/apt");
+   #endif

    return true;
 }


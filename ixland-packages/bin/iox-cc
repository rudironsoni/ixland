#!/bin/bash
# iox-cc - Linux-to-iOS Cross Compiler
# Usage: iox-cc [options] file...

set -e

# Configuration
IOX_PREFIX="${IOX_PREFIX:-/usr/local}"
IOX_SYSROOT="${IOX_SYSROOT:-${IOX_PREFIX}/share/iox/sysroot}"

# iOS SDK detection
IOSSDK_PATH="${IOSSDK_PATH:-$(xcrun --sdk iphoneos --show-sdk-path 2>/dev/null || echo '')}"
if [ -z "$IOSSDK_PATH" ]; then
    echo "Error: iOS SDK not found" >&2
    exit 1
fi

# Default target
TARGET="${IOX_TARGET:-arm64-apple-ios16.0}"

# Parse arguments
OUTPUT=""
SOURCES=()
ARGS=()
LINK_IOX=true
VERBOSE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -o)
            OUTPUT="$2"
            ARGS+=("$1" "$2")
            shift 2
            ;;
        -c)
            LINK_IOX=false
            ARGS+=("$1")
            shift
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        --target=*)
            TARGET="${1#*=}"
            shift
            ;;
        --sysroot=*)
            IOX_SYSROOT="${1#*=}"
            shift
            ;;
        --help)
            cat << 'EOF'
iox-cc - Linux-to-iOS Cross Compiler

Usage: iox-cc [options] file...

Options:
  -o <file>           Output file
  -c                  Compile only (don't link)
  -v, --verbose       Verbose output
  --target=<triple>   Target triple (default: arm64-apple-ios16.0)
  --sysroot=<path>    System root path
  --help              Show this help

Environment Variables:
  IOX_PREFIX          Installation prefix (default: /usr/local)
  IOX_TARGET          Target triple
  IOX_SYSROOT         System root for headers and libraries
  IOSSDK_PATH         iOS SDK path

Examples:
  iox-cc hello.c -o hello
  iox-cc -c module.c -o module.o
  iox-cc --target=x86_64-apple-ios16.0-simulator test.c

EOF
            exit 0
            ;;
        -*)
            ARGS+=("$1")
            shift
            ;;
        *)
            SOURCES+=("$1")
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Compiler flags
CFLAGS=(
    "-target" "$TARGET"
    "-isysroot" "$IOSSDK_PATH"
    "-isystem" "${IOX_PREFIX}/include/iox"
    "-isystem" "${IOX_PREFIX}/include/iox/sys"
    "-I${IOX_SYSROOT}/usr/include"
    "-D__IOX__=1"
    "-D__linux__=1"  # Pretend to be Linux for compatibility
)

# Linker flags
LDFLAGS=()
if $LINK_IOX; then
    LDFLAGS+=(
        "-L${IOX_PREFIX}/lib"
        "-liox"
        "-lpthread"
        "-Wl,-e,_iox_start"  # Custom entry point
    )
fi

# Debug output
if $VERBOSE; then
    echo "iox-cc: Target: $TARGET"
    echo "iox-cc: iOS SDK: $IOSSDK_PATH"
    echo "iox-cc: IOX Prefix: $IOX_PREFIX"
    echo "iox-cc: Sources: ${SOURCES[*]}"
    echo "iox-cc: CFLAGS: ${CFLAGS[*]}"
    $LINK_IOX && echo "iox-cc: LDFLAGS: ${LDFLAGS[*]}"
fi

# Compile and link
if $LINK_IOX; then
    clang "${CFLAGS[@]}" "${ARGS[@]}" "${LDFLAGS[@]}"
else
    clang "${CFLAGS[@]}" "${ARGS[@]}"
fi

exit 0
